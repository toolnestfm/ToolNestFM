# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — never expose to client)
# Required for: newsletter, contact form, analytics, search logs, Stripe webhook
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini AI (server-only) — powers /api/ai/chat
GEMINI_API_KEY=

# Stripe (server-only) — powers Upgrade to Pro
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=

# ─── FAB Cloud (Pro) — Google Drive + Dropbox OAuth ─────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Enable: Google Drive API. Authorized redirect URI (add BOTH for dev + prod):
#   http://localhost:3000/api/cloud/google/callback
#   https://toolnestfm.com/api/cloud/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — for Drive file picker UI (Google Cloud → APIs → Picker API)
GOOGLE_PICKER_API_KEY=
GOOGLE_APP_ID=

# Dropbox App Console → https://www.dropbox.com/developers/apps
# App type: Scoped access. Permissions: files.content.read, files.content.write
# Redirect URI:
#   http://localhost:3000/api/cloud/dropbox/callback
#   https://toolnestfm.com/api/cloud/dropbox/callback
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# ─── Share link cron cleanup ─────────────────────────────────────────────────
# Random string (e.g. openssl rand -hex 32). Vercel Cron calls:
#   GET https://toolnestfm.com/api/cron/cleanup-shares
#   Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
